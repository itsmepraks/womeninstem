# Vercel ignore file
# These files/directories don't need to be uploaded to Vercel

# Documentation
*.md
!README.md

# Development files
.prettierrc
.eslintrc.json

# Git
.git
.gitignore

# Dependencies (will be installed by Vercel)
node_modules

# Build output (will be generated by Vercel)
.next
out

# Environment files (use Vercel environment variables instead)
.env*.local
