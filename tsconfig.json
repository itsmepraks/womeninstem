{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/app/*": ["./app/*"],
      "@/lib/*": ["./lib/*"],
      "@/public/*": ["./public/*"]
    },
    "forceConsistentCasingInFileNames": true,
    
    // Stricter type checking options for better code quality
    "noUnusedLocals": true,             // Report errors on unused local variables
    "noUnusedParameters": true,         // Report errors on unused function parameters
    "noImplicitReturns": true,          // Ensure all code paths in a function return a value
    "noUncheckedIndexedAccess": true,   // Add undefined to type when accessing array/object with index
    "noFallthroughCasesInSwitch": true  // Report errors for fallthrough cases in switch statements
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
