# Required for /api/cron/refresh. Vercel injects this automatically in production.
# For local testing, set to any random string and pass as `Authorization: Bearer <secret>`.
CRON_SECRET=

# Optional. Raises rate limits on GitHub-based fetchers (orgs, mentors).
# Create at https://github.com/settings/tokens with no scopes (public read only).
GITHUB_TOKEN=
