    "lucide-react": "^0.344.0",
    "next": "^14.2.0",
    "next-themes": "^0.2.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.50.0",
    "react-leaflet": "4.2.1",
    "react-pageflip": "^2.0.3",
